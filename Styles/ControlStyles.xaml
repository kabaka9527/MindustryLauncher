<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="LauncherPageTitleTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{ThemeResource LauncherFontFamily}" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextWrapping" Value="WrapWholeWords" />
    </Style>

    <Style x:Key="LauncherSectionTitleTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{ThemeResource LauncherFontFamily}" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextWrapping" Value="WrapWholeWords" />
    </Style>

    <Style x:Key="LauncherCaptionTextBlockStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        <Setter Property="TextWrapping" Value="WrapWholeWords" />
    </Style>

    <Style x:Key="LauncherCardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{ThemeResource LauncherCardCornerRadius}" />
        <Setter Property="Padding" Value="{ThemeResource LauncherCardPadding}" />
    </Style>

    <Style x:Key="LauncherQuietCardBorderStyle" TargetType="Border" BasedOn="{StaticResource LauncherCardBorderStyle}">
        <Setter Property="Background" Value="{ThemeResource LayerFillColorDefaultBrush}" />
    </Style>

    <Style x:Key="LauncherCommandBarStyle" TargetType="CommandBar">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="DefaultLabelPosition" Value="Right" />
        <Setter Property="IsDynamicOverflowEnabled" Value="True" />
        <Setter Property="OverflowButtonVisibility" Value="Auto" />
    </Style>

    <Style TargetType="CommandBar" BasedOn="{StaticResource LauncherCommandBarStyle}" />

    <Style x:Key="LauncherListViewItemStyle" TargetType="ListViewItem">
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <Style x:Key="LauncherIconButtonStyle" TargetType="Button">
        <Setter Property="MinWidth" Value="36" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="Padding" Value="10,6" />
    </Style>
</ResourceDictionary>

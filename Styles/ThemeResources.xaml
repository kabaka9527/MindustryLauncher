<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="LauncherAccentBrush" Color="#0067C0" />
            <SolidColorBrush x:Key="LauncherSuccessBrush" Color="#0F7B0F" />
            <SolidColorBrush x:Key="LauncherWarningBrush" Color="#9D5D00" />
            <SolidColorBrush x:Key="LauncherDangerBrush" Color="#C42B1C" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="LauncherAccentBrush" Color="#60CDFF" />
            <SolidColorBrush x:Key="LauncherSuccessBrush" Color="#6CCB5F" />
            <SolidColorBrush x:Key="LauncherWarningBrush" Color="#FCE100" />
            <SolidColorBrush x:Key="LauncherDangerBrush" Color="#FF99A4" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="HighContrast">
            <SolidColorBrush x:Key="LauncherAccentBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="LauncherSuccessBrush" Color="{ThemeResource SystemColorTextColor}" />
            <SolidColorBrush x:Key="LauncherWarningBrush" Color="{ThemeResource SystemColorTextColor}" />
            <SolidColorBrush x:Key="LauncherDangerBrush" Color="{ThemeResource SystemColorTextColor}" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <Thickness x:Key="LauncherPagePadding">28,24,28,28</Thickness>
    <Thickness x:Key="LauncherCompactPagePadding">16,16,16,20</Thickness>
    <Thickness x:Key="LauncherCardPadding">16</Thickness>
    <CornerRadius x:Key="LauncherCardCornerRadius">8</CornerRadius>
    <x:Double x:Key="LauncherCardSpacing">12</x:Double>
    <x:Double x:Key="LauncherContentMaxWidth">1180</x:Double>
    <x:Double x:Key="LauncherCompactWidthBreakpoint">720</x:Double>
    <x:Double x:Key="LauncherCommandCompactBreakpoint">620</x:Double>
    <x:Double x:Key="LauncherMetricMediumBreakpoint">560</x:Double>
    <x:Double x:Key="LauncherMetricWideBreakpoint">900</x:Double>
    <x:Double x:Key="LauncherChannelMediumBreakpoint">520</x:Double>
    <x:Double x:Key="LauncherChannelWideBreakpoint">820</x:Double>
    <x:Double x:Key="LauncherSettingsTwoColumnBreakpoint">760</x:Double>
    <FontFamily x:Key="LauncherFontFamily">Segoe UI Variable Text</FontFamily>
</ResourceDictionary>

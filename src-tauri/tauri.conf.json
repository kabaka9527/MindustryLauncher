{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mindustry Launcher",
  "version": "0.1.0",
  "identifier": "xyz.kabaka.mindustrylauncher",
  "build": {
    "beforeDevCommand": "pnpm dev:web",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mindustry Launcher",
        "width": 1180,
        "height": 760,
        "minWidth": 960,
        "minHeight": 640,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "category": "Game",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
